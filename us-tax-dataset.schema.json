{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/cboxdk/us-tax-dataset/blob/main/us-tax-dataset.schema.json",
    "title": "Cbox US Tax Dataset",
    "description": "US sales-tax dataset: rates with effective windows, economic-nexus thresholds and product taxability. Citations are deduplicated into a top-level `sources` registry referenced by `sourceId`; rate records are keyed by jurisdictionCode. Additive changes are NOT breaking — consumers MUST ignore unknown fields; schemaVersion bumps only on breaking changes.",
    "type": "object",
    "required": ["schemaVersion", "version", "generatedAt", "asOf", "contentHash", "coverage", "sources", "states"],
    "properties": {
        "schemaVersion": { "type": "integer", "const": 3 },
        "version": { "type": "string", "format": "date" },
        "generatedAt": { "type": "string" },
        "asOf": { "type": "string", "format": "date" },
        "contentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "sourceHealth": {
            "type": "object",
            "properties": {
                "staleSources": {
                    "type": "object",
                    "description": "URLs served from the committed cache because the live source is down — empty object when all sources are healthy.",
                    "additionalProperties": {
                        "type": "object",
                        "required": ["cachedFrom", "error"],
                        "properties": {
                            "cachedFrom": { "type": "string", "format": "date" },
                            "error": { "type": "string" }
                        }
                    }
                }
            }
        },
        "coverage": {
            "type": "object",
            "required": ["localRates", "stateComplete", "stateOnly", "noSalesTax", "nexus", "taxability", "sourcing"],
            "properties": {
                "localRates": { "$ref": "#/$defs/subdivisionList" },
                "stateComplete": { "$ref": "#/$defs/subdivisionList" },
                "stateOnly": { "$ref": "#/$defs/subdivisionList" },
                "noSalesTax": { "$ref": "#/$defs/subdivisionList" },
                "nexus": { "$ref": "#/$defs/subdivisionList" },
                "taxability": { "$ref": "#/$defs/subdivisionList" },
                "sourcing": { "$ref": "#/$defs/subdivisionList" }
            }
        },
        "sources": {
            "type": "object",
            "description": "Deduplicated citation registry: sourceId => citation. Every `sourceId` in the dataset resolves here.",
            "additionalProperties": { "$ref": "#/$defs/citation" }
        },
        "states": {
            "type": "object",
            "minProperties": 51,
            "propertyNames": { "pattern": "^US-[A-Z]{2}$" },
            "additionalProperties": { "$ref": "#/$defs/state" }
        }
    },
    "$defs": {
        "subdivisionList": {
            "type": "array",
            "items": { "type": "string", "pattern": "^US-[A-Z]{2}$" }
        },
        "citation": {
            "type": "object",
            "required": ["name", "retrievedAt"],
            "properties": {
                "name": { "type": "string" },
                "url": { "type": ["string", "null"] },
                "retrievedAt": { "type": "string", "format": "date" }
            }
        },
        "state": {
            "type": "object",
            "required": ["coverage", "rates", "baseline", "nexus", "taxability", "sourcing"],
            "properties": {
                "coverage": { "enum": ["locals", "state_complete", "state_only", "none"] },
                "rates": {
                    "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/rates" }]
                },
                "baseline": {
                    "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/baseline" }]
                },
                "nexus": {
                    "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/nexus" }]
                },
                "taxability": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/taxabilityRule" }
                },
                "sourcing": {
                    "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sourcing" }]
                }
            }
        },
        "rates": {
            "type": "object",
            "required": ["stateFips", "rateBasis", "stateRate", "sourceMode", "state", "local", "provenance"],
            "properties": {
                "stateFips": { "type": "string", "pattern": "^[0-9]{2}$" },
                "rateBasis": {
                    "enum": ["component", "combined"],
                    "description": "component: add stateRate to the applicable local records. combined: one record IS the all-in total (stateRate already inside) — summing double-counts."
                },
                "stateRate": {
                    "type": ["number", "null"],
                    "description": "The applicable state rate, inlined so this section is self-contained: add it to component locals; it is already inside a combined total."
                },
                "sourceMode": { "enum": ["official_files", "curated"] },
                "state": { "$ref": "#/$defs/rateRecordsByCode" },
                "local": { "$ref": "#/$defs/rateRecordsByCode" },
                "note": { "type": ["string", "null"] },
                "excludedLocations": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Locations the source flags as not uniformly rateable — refusals, not omissions."
                },
                "sourceDown": {
                    "type": "object",
                    "description": "Present when this state's data file was served from the committed cache because the live source is down.",
                    "required": ["cachedFrom", "error"],
                    "properties": {
                        "cachedFrom": { "type": "string", "format": "date" },
                        "error": { "type": "string" }
                    }
                },
                "provenance": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "object",
                        "required": ["url", "fileName", "sha256", "retrievedAt"],
                        "properties": {
                            "url": { "type": "string" },
                            "fileName": { "type": "string" },
                            "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                            "retrievedAt": { "type": "string" }
                        }
                    }
                }
            }
        },
        "rateRecordsByCode": {
            "type": "object",
            "description": "jurisdictionCode => list of rate records (one entry per effective window). The code is the key, so it is not repeated inside each record.",
            "additionalProperties": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/rateRecord" }
            }
        },
        "rateRecord": {
            "type": "object",
            "required": ["level", "generalRate", "effectiveFrom", "effectiveTo"],
            "properties": {
                "level": { "enum": ["state", "county", "city", "special_district", "local"] },
                "jurisdictionName": { "type": ["string", "null"] },
                "generalRate": { "type": "number", "minimum": 0, "maximum": 0.25 },
                "generalRateIntrastate": { "type": ["number", "null"] },
                "foodDrugRate": { "type": ["number", "null"] },
                "effectiveFrom": { "type": ["string", "null"], "description": "Y-m-d; null for undated snapshots." },
                "effectiveTo": { "type": ["string", "null"], "description": "Y-m-d; null = until changed." }
            }
        },
        "baseline": {
            "type": "object",
            "required": ["stateRate", "localsExist", "noSalesTax", "sourceId"],
            "properties": {
                "stateRate": { "type": ["number", "null"] },
                "localsExist": { "type": "boolean" },
                "noSalesTax": { "type": "boolean" },
                "includesMandatoryLocalComponents": { "type": "boolean" },
                "note": { "type": ["string", "null"] },
                "sourceId": { "type": "string", "description": "References a citation in the top-level `sources` registry." }
            }
        },
        "nexus": {
            "type": "object",
            "required": ["salesUsd", "transactions", "combinator", "sourceId"],
            "properties": {
                "salesUsd": { "type": "integer", "minimum": 0 },
                "transactions": { "type": ["integer", "null"] },
                "combinator": { "enum": ["sales_only", "sales_or_transactions", "sales_and_transactions"] },
                "sourceId": { "type": "string", "description": "References a citation in the top-level `sources` registry." }
            }
        },
        "taxabilityRule": {
            "type": "object",
            "required": ["category", "taxable", "treatment", "sourceId"],
            "properties": {
                "category": { "type": "string" },
                "taxable": {
                    "type": "boolean",
                    "description": "Coarse signal derived from treatment: false only for exempt, true otherwise. Use treatment + conditions for the exact rule."
                },
                "treatment": {
                    "enum": ["taxable", "exempt", "reduced_rate", "conditional"],
                    "description": "taxable/exempt at the general rate, or reduced_rate/conditional with structured conditions."
                },
                "conditions": {
                    "type": ["object", "null"],
                    "description": "Structured nuance for reduced_rate (e.g. {\"rate\": 0.02}) and conditional (e.g. {\"exemptBelowCents\": 17500}) treatments; null otherwise."
                },
                "sourceId": { "type": "string", "description": "References a citation in the top-level `sources` registry." }
            }
        },
        "sourcing": {
            "type": "object",
            "required": ["mode", "note", "sourceId"],
            "properties": {
                "mode": {
                    "enum": ["origin", "destination", "mixed"],
                    "description": "Intrastate sourcing: origin follows the seller, destination the buyer, mixed splits by jurisdiction layer or seller type (see note). Interstate/remote sales are destination-sourced regardless."
                },
                "note": { "type": ["string", "null"] },
                "sourceId": { "type": "string", "description": "References a citation in the top-level `sources` registry." }
            }
        }
    }
}
